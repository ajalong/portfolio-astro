---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROJECT_THUMBNAIL_ALTS } from '../data/projectThumbnailAlts';
import { getLastUpdatedLabel } from '../data/lastUpdated';
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import HomeSectionIndex from '../components/HomeSectionIndex.astro';
import NavSd from '../components/NavSd.astro';
import LogoCarousel from '../components/LogoCarousel.astro';
import { homeLogos } from '../data/homeLogos';
import { resolveThumbnails } from '../lib/cloudinary.mjs';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.data.published !== false)
  .sort((a, b) => a.data.order - b.data.order);

// Resolve thumbnail URLs once per project — accepts either the new
// `thumbnail` (public-id + mediaBase) shape or the legacy
// `thumbnailImage` / `thumbnailVideo` full URLs.
const projectThumbs = new Map(
  projects.map((p) => [(p.data.slug ?? p.id), resolveThumbnails(p.data)]),
);

// A project gets the full showcase block when it carries both the
// frontmatter impact metrics and the showcase media. Otherwise it
// renders as the standard ProjectCard.
const hasShowcase = (p: typeof projects[number]): boolean =>
  Boolean(p.data.impactMetrics?.length && p.data.showcaseMedia);

// Top-level page sections the nav jumps between. Each section needs a
// stable DOM id on the corresponding element below (see `#about`,
// `#projects`) so the shared IntersectionObserver-driven active-state
// tracking picks it up. Update in lockstep with the page structure.
//
// Today: About + Projects.
// Future: + Posts (insert between About and Projects when shipped).
const pageSections = [
  { id: 'about', label: 'About' },
  { id: 'projects', label: 'Projects' },
];

const subtitle = getLastUpdatedLabel();
---
<BaseLayout
  title="Alan Long"
  description="Senior Product Designer with a front-end background. Former member of Interbrand's design team and led design and development at Cheerful Twentyfirst."
  bodyClass="home"
>
  <div class="page_container">
    <header>
      <div class="profile-info">
        <div class="display-name">
          <h1>Alan Long</h1>
        </div>
        <p>Senior Product Designer</p>
      </div>
      <div class="about" id="about">
        <p class="text-display">Five years at agencies in London, with clients across pharma, automotive, engineering and media.</p>
        <p class="text-display">Brand skills from my time at <a href="https://interbrand.com/" target="_blank" rel="noopener noreferrer">Interbrand</a>, and a front-end background that keeps me close to implementation. Both feed a systems-led approach to design that runs from high-level architectural choices through to visual craft.</p>
        <p class="text-display">This site was designed and built with the help of AI. The projects showcased here predate the most recent advancements in AI, however, if done today, AI would be used heavily throughout.</p>
      </div>
    </header>
    <HomeSectionIndex sections={pageSections} subtitle={subtitle} />
    {/* Home variant of the SdNav — no back link, no centre label. The
        dropdown lists the home's page-level sections (About, Projects),
        not individual projects. Shared component with the project pages
        (same structure + script + styles). */}
    <NavSd sections={pageSections} showBackLink={false} backLabel="alanlong.design" centerLabel="" centerLabelShort="" ariaLabel="Home sections" />
    <LogoCarousel logos={homeLogos} />
    <main id="main-content">
      <ul class="project-list" id="projects">
        {
          projects.map((project, i) => (
            <li
              id={`project-${(project.data.slug ?? project.id)}`}
              data-bg-section
              data-brand-primary={project.data.brand?.primary}
              data-brand-secondary={project.data.brand?.secondary}
            >
              {hasShowcase(project) ? (
                <ProjectShowcase project={project} />
              ) : (
                <ProjectCard
                  href={`/project/${(project.data.slug ?? project.id)}`}
                  thumbnailSrc={projectThumbs.get((project.data.slug ?? project.id))?.poster}
                  thumbnailAlt={
                    PROJECT_THUMBNAIL_ALTS[(project.data.slug ?? project.id)] ?? `${project.data.title} thumbnail`
                  }
                  thumbnailVideo={projectThumbs.get((project.data.slug ?? project.id))?.video ?? undefined}
                  projectTitle={project.data.title}
                  client={project.data.client}
                  summary={project.data.summary}
                  belowFold={i > 0}
                />
              )}
            </li>
          ))
        }
      </ul>
    </main>
  </div>
  <script>
    import { initBackgroundObserver } from '../scripts/bg-observer';
    import { initShowcaseOverflowObservers } from '../scripts/showcase-overflow';
    document.addEventListener('astro:page-load', () => {
      initBackgroundObserver();
      initShowcaseOverflowObservers();
    });
  </script>
</BaseLayout>
