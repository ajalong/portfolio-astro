---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { resolveThumbnails } from '../../lib/cloudinary.mjs';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

type ProjectEntry = CollectionEntry<'projects'>;

export async function getStaticPaths() {
  const all = await getCollection('projects');
  const published = all.filter((p) => p.data.published !== false);
  const sorted = [...published].sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, i) => ({
    params: { slug: project.data.slug ?? project.id },
    props: { project, nextProject: sorted[(i + 1) % sorted.length] },
  }));
}

interface Props {
  project: ProjectEntry;
  nextProject: ProjectEntry;
}

const { project, nextProject } = Astro.props as Props;

const { title, client, metaDescription, year, sector, industry, theme, roleTitle, roleSummary, brand } = project.data;
const { poster: thumbnailImage } = resolveThumbnails(project.data);

const { Content } = await render(project);

// Section index is auto-derived from the markdown body. Each italic-only
// paragraph (`_Kicker_`) immediately followed by a heading (`##` or `###`)
// becomes a nav entry — the kicker is both the label and (slugified) the id.
// h2 sections are top-level; h3 sections nest under the most recent h2.
//
// The "My role" panel is rendered by ProjectLayout from the `team` frontmatter
// (not from markdown), so it's auto-prepended when team data exists.
type SectionEntry = { id: string; label: string; children?: SectionEntry[] };
function slugify(s: string) {
  return s
    .toLowerCase()
    .trim()
    .replace(/[''']/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}
function parseSectionIndex(body: string, hasTeam: boolean): SectionEntry[] | undefined {
  // Section index lists only top-level h2 sections. h3 sub-sections are
  // surfaced as cards-and-modal-overlays inside their parent section, not
  // as nav targets, so they're intentionally excluded here.
  const newRe = /^_([^_\n]+)_\s*\n+##\s+/gm;
  const legacyRe = /<section\s+([^>]+)>\s*\n+\s*<p class="kicker">([^<]+)<\/p>/g;

  type Hit = { idx: number; id: string; label: string };
  const hits: Hit[] = [];
  let m: RegExpExecArray | null;
  while ((m = newRe.exec(body))) {
    const label = m[1].trim();
    hits.push({ idx: m.index, id: slugify(label), label });
  }
  while ((m = legacyRe.exec(body))) {
    const attrs = m[1];
    if (attrs.includes('data-parent=')) continue; // skip legacy h3
    const id = attrs.match(/id="([^"]+)"/)?.[1];
    if (!id) continue;
    hits.push({ idx: m.index, id, label: m[2].trim() });
  }
  hits.sort((a, b) => a.idx - b.idx);
  if (hits.length < 2) return undefined;
  const roots: SectionEntry[] = hits.map((h) => ({ id: h.id, label: h.label }));
  if (hasTeam) roots.unshift({ id: 'my-role', label: 'My role' });
  return roots;
}
const sectionIndex = parseSectionIndex(project.body, !!project.data.team?.length);
---
<ProjectLayout
  title={title}
  client={client}
  description={metaDescription}
  image={thumbnailImage}
  year={year}
  sector={sector}
  industry={industry}
  theme={theme}
  team={project.data.team}
  orgs={project.data.orgs}
  nextProject={nextProject}
  {sectionIndex}
  {roleTitle}
  {roleSummary}
  brandPrimary={brand?.primary}
  brandSecondary={brand?.secondary}
>
  <article>
    <Content />
  </article>
</ProjectLayout>

