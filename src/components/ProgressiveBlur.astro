---
/**
 * Progressive blur cap — the site's standard "content softens into a
 * solid edge" effect. Used at the top of pages, inside the project-team
 * overlay's chrome, and at the left/right edges of the homepage logo
 * carousel. One implementation, four directions.
 *
 * Layered backdrop-filter stack masked by linear gradients gives a
 * perceptually smooth Gaussian falloff from heavy blur at the outer
 * edge to ~zero at the inner edge. A 21-stop quadratic tint gradient
 * sits on top (with SVG noise dither) to merge the cap into the
 * surface it sits on.
 *
 * Why N layers, not one with a single mask:
 * A single backdrop-filter + mask gives a hard halo at the mask edge
 * (blur intensity is binary inside the mask, only opacity varies).
 * Stacking 4 layers with overlapping masks and a 1-2-4-8 radius ramp
 * approximates a continuous Gaussian curve and eliminates the halo.
 *
 * Sizing optimisation: each layer is positioned to span only the
 * cap-region where its mask is non-zero, not the full cap. backdrop-
 * filter blurs the layer's full bounding box regardless of mask alpha,
 * so trimming the layer cuts blur work proportionally. Net blur area
 * per frame: 225% of cap area (75+75+50+25), down from 400% with a
 * full-extent stack — ~44% reduction.
 *
 * Blur ramp 1-2-4-8 (geometric, 2× per step). Earlier tried 1-3-6-12
 * for a more dramatic top blur but the heaviest layer's per-pixel cost
 * dominated (kernel area scales quadratically). 1-2-4-8 keeps a
 * visible step between levels while halving the heaviest layer's cost.
 *
 * Accessibility: prefers-reduced-transparency: reduce collapses the
 * stack to a single linear-gradient fade with no blur (see
 * _progressive-blur.scss). Same visual intent, cheap and accessible.
 */
type Direction = 'top' | 'bottom' | 'left' | 'right';

interface Props {
  /**
   * The edge content fades TOWARDS — the solid end. Default 'top'
   * (page cap: fades upward into the page background). 'left' and
   * 'right' are the horizontal variants used by the logo carousel.
   */
  direction?: Direction;
  /**
   * Distance from the solid edge to the transparent end. For 'top'/
   * 'bottom' this is a height; for 'left'/'right' a width. Defaults
   * to `--cap-height` (the page-cap value defined in _tokens.scss) so
   * the default invocation matches the page cap.
   */
  extent?: string;
  /**
   * Colour the cap merges into at its solid edge. Each context has a
   * different surface — page bg for the page cap, panel surface for
   * the team overlay chrome, card surface for the carousel edges. The
   * 21-stop quadratic tint is generated from this colour via the
   * `from <colour>` relative-colour syntax in _progressive-blur.scss.
   */
  tintColor?: string;
  /**
   * Extra class on the wrapper — lets a caller override the default
   * fixed-to-viewport positioning (e.g. mount the cap inside a card
   * chrome with `position: absolute`).
   */
  class?: string;
}

const {
  direction = 'top',
  extent = 'var(--cap-height)',
  tintColor = 'var(--backgroundColor)',
  class: className,
} = Astro.props as Props;

// Layer table is direction-agnostic — `region` and `stops` are
// expressed in cap-relative %, where 0% = the transparent (inner)
// end and 100% = the solid (outer) end. The position+mask emitters
// below project these onto whichever physical axis the direction
// implies.
//
// The lowest layer's `region.start` is offset slightly above 0
// (cap-pct 5) so its bounding box doesn't sit right at the cap's
// transparent edge. The mask still tapers to alpha 0 at the layer's
// bottom, but that bottom is now 5% inside the cap rather than at
// the boundary where page content meets the cap — where backdrop-
// filter can produce a sub-pixel compositing seam. The tint
// gradient is buffered to match (see `_progressive-blur.scss`),
// keeping the bottom 5% of the cap a flat alpha-0 zone with neither
// blur nor tint, so the cap fades into page content imperceptibly.
type Layer = {
  blur: number;
  region: { start: number; end: number }; // start = inner, end = outer
  stops: Array<{ pos: number; alpha: number }>;
};
const layers: Layer[] = [
  {
    blur: 1,
    region: { start: 5, end: 75 },
    stops: [
      { pos: 5,  alpha: 0 },
      { pos: 25, alpha: 1 },
      { pos: 50, alpha: 1 },
      { pos: 75, alpha: 0 },
    ],
  },
  {
    blur: 2,
    region: { start: 25, end: 100 },
    stops: [
      { pos: 25,  alpha: 0 },
      { pos: 50,  alpha: 1 },
      { pos: 75,  alpha: 1 },
      { pos: 100, alpha: 0 },
    ],
  },
  {
    blur: 4,
    region: { start: 50, end: 100 },
    stops: [
      { pos: 50,  alpha: 0 },
      { pos: 75,  alpha: 1 },
      { pos: 100, alpha: 1 },
    ],
  },
  {
    blur: 8,
    region: { start: 75, end: 100 },
    stops: [
      { pos: 75,  alpha: 0 },
      { pos: 100, alpha: 1 },
    ],
  },
];

// CSS gradient-direction string per fade direction. "to top" means
// the gradient runs bottom→top, so opaque ends up at the top edge.
const gradientDirection: Record<Direction, string> = {
  top: 'to top',
  bottom: 'to bottom',
  left: 'to left',
  right: 'to right',
};

function maskGradient(layer: Layer): string {
  const span = layer.region.end - layer.region.start;
  const segments = layer.stops.map((s) => {
    const layerPct = ((s.pos - layer.region.start) / span) * 100;
    return `rgba(0,0,0,${s.alpha}) ${layerPct.toFixed(2)}%`;
  }).join(', ');
  return `linear-gradient(${gradientDirection[direction]}, ${segments})`;
}

// Project a layer's `start`/`end` region onto the appropriate axis,
// trimming the layer's bounding box to its visible span. The axis
// that the cap fades along carries the trim; the cross-axis fills.
function layerPosition(layer: Layer): string {
  const startInset = `${layer.region.start}%`;
  const endInset = `${100 - layer.region.end}%`;
  switch (direction) {
    case 'top':
      return `bottom: ${startInset}; top: ${endInset}; left: 0; right: 0;`;
    case 'bottom':
      return `top: ${startInset}; bottom: ${endInset}; left: 0; right: 0;`;
    case 'left':
      return `right: ${startInset}; left: ${endInset}; top: 0; bottom: 0;`;
    case 'right':
      return `left: ${startInset}; right: ${endInset}; top: 0; bottom: 0;`;
  }
}

// Wrapper sets the two custom properties the SCSS consumes:
//   --pb-extent    – the dimension along the fade axis
//   --pb-grad-dir  – the tint-gradient direction
//   --pb-tint      – the surface colour at the solid edge
const wrapperStyle = [
  `--pb-extent: ${extent}`,
  `--pb-grad-dir: ${gradientDirection[direction]}`,
  `--pb-tint: ${tintColor}`,
].join('; ');
---

<div
  class:list={['progressive-blur', `progressive-blur--${direction}`, className]}
  style={wrapperStyle}
  aria-hidden="true"
>
  {layers.map((l, i) => {
    const mask = maskGradient(l);
    return (
      <div
        class="progressive-blur__layer"
        style={`z-index: ${i + 1}; ${layerPosition(l)} backdrop-filter: blur(${l.blur}px); -webkit-backdrop-filter: blur(${l.blur}px); mask-image: ${mask}; -webkit-mask-image: ${mask};`}
      />
    );
  })}
</div>
