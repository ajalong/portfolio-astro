---
interface Props {
  href: string;
  thumbnailSrc: string;
  thumbnailAlt: string;
  thumbnailVideo?: string;
  projectTitle: string;
  client: string;
  summary: string;
  // Below-fold cards get fetchpriority="low" so the browser still loads them
  // eagerly but behind LCP-relevant requests. Avoids the visible pop-in that
  // `loading="lazy"` causes when scrolling reaches a card before its poster
  // has fetched.
  belowFold?: boolean;
}

const {
  href,
  thumbnailSrc,
  thumbnailAlt,
  thumbnailVideo,
  projectTitle,
  client,
  summary,
  belowFold = false,
} = Astro.props as Props;

const fetchPriority = belowFold ? 'low' : undefined;
---

<a class="item" href={href} data-zip-on-hover>
  <div class="thumbnail">
    {thumbnailVideo ? (
      <video
        class="thumbnail-video"
        src={thumbnailVideo}
        poster={thumbnailSrc}
        loop
        muted
        playsinline
        preload="metadata"
        fetchpriority={fetchPriority}
        aria-label={thumbnailAlt}
        data-thumbnail-video
        data-autoplay-on-view
      ></video>
    ) : (
      <img alt={thumbnailAlt} src={thumbnailSrc} fetchpriority={fetchPriority} />
    )}
    <div class="thumbnail-caption">
      <h3 class="thumbnail-title">{projectTitle}</h3>
      <p class="thumbnail-client">{client}</p>
      <p class="item-meta">{summary}</p>
      <span class="item-cta" aria-hidden="true">See the work</span>
    </div>
  </div>
</a>
