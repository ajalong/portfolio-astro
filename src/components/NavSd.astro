---
import IconArrowLeft from './icons/IconArrowLeft.astro';
import IconChevronDown from './icons/IconChevronDown.astro';

/**
 * Standard-viewport section nav. Used on BOTH project pages and the home
 * page — the structure (bar + dropdown), styling (.nav-sd*), and
 * script (nav-sd.ts) are identical; only the bar's back/center
 * content differs, driven by props.
 *
 * Below $breakpoint-large only. A fixed bar pinned 16px from the top of
 * the viewport, spanning the page-grid content width (--page-gutter-x
 * left and right).
 *
 * Bar layout (3 equal-width cells):
 *
 *   ← alanlong.design     |     GSK     |     System architecture ⌄
 *      (back cell)            (center)      (active section + toggle)
 *
 * The right-hand toggle opens a dropdown menu below the bar containing
 * the section jump-links — same set as NavLg, same active-section
 * tracking. Both navs subscribe to `trackActiveSection`; this one updates
 * the bar's section label + the menu's data-active state from there.
 *
 * Props for context adaptation:
 *
 *   backHref       — back link target. Default "/" (home). Ignored when
 *                    `showBackLink` is false.
 *   backLabel      — back-cell text. Default "Back".
 *   centerLabel    — middle-cell text (medium viewport ≥ $breakpoint-medium).
 *                    Default "alanlong.design/<slug>" on `/project/<slug>`
 *                    pages; empty string elsewhere leaves the cell blank.
 *   centerLabelShort — middle-cell text on mobile (≤ $breakpoint-medium)
 *                    where the full URL gets cramped. Project pages pass
 *                    the client name (e.g. "GSK") so the compact label
 *                    reads as the project identity rather than a URL
 *                    fragment. Defaults to the bare slug as a fallback
 *                    for callers that don't pass anything (e.g. preview
 *                    routes); pass an explicit empty string to keep
 *                    mobile blank.
 *   ariaLabel      — <nav> aria-label. Default "Case study sections".
 *   showBackLink   — when true (default) the back cell is a link with
 *                    the back arrow. When false (used on the home page,
 *                    where "back" has no destination), the cell renders
 *                    as a static label only — no arrow, no link. The
 *                    label text still shows.
 */

interface SectionEntry {
  id: string;
  label: string;
  children?: SectionEntry[];
}

interface Props {
  sections: SectionEntry[];
  backHref?: string;
  backLabel?: string;
  centerLabel?: string;
  centerLabelShort?: string;
  ariaLabel?: string;
  showBackLink?: boolean;
}

// Default center labels are derived from the URL slug for project pages.
// `/project/gsk` → full "alanlong.design/gsk" (medium+), short "gsk"
// (mobile). Both empty on any other page.
const slugMatch = Astro.url.pathname.match(/^\/project\/([^/]+)/);
const defaultCenterLabel = slugMatch ? `alanlong.design/${slugMatch[1]}` : '';
const defaultCenterLabelShort = slugMatch ? slugMatch[1] : '';

const {
  sections,
  backHref = '/',
  backLabel = 'Back',
  centerLabel = defaultCenterLabel,
  centerLabelShort = defaultCenterLabelShort,
  ariaLabel = 'Case study sections',
  showBackLink = true,
} = Astro.props as Props;

// Flatten the nested section config — same as NavLg.
type FlatEntry = SectionEntry & { depth: number };
function flatten(items: SectionEntry[], depth = 0, out: FlatEntry[] = []): FlatEntry[] {
  for (const it of items) {
    out.push({ id: it.id, label: it.label, depth });
    if (it.children?.length) flatten(it.children, depth + 1, out);
  }
  return out;
}
const flatSections = flatten(sections);
// Default closed-state section label: the first section. Script swaps this
// out for the actually-active section as soon as `trackActiveSection` reports.
const defaultActiveLabel = flatSections[0]?.label ?? '';
---

{sections && sections.length > 0 && (
  <nav
    class="nav-sd"
    aria-label={ariaLabel}
    data-nav-sd
  >
    <div class="nav-sd__bar">
      {showBackLink ? (
        <a class="nav-sd__back btn-secondary" href={backHref}>
          <IconArrowLeft class="nav-sd__back-arrow" />
          <span class="nav-sd__back-label">{backLabel}</span>
        </a>
      ) : (
        <span class="nav-sd__back nav-sd__back--static">
          <span class="nav-sd__back-label">{backLabel}</span>
        </span>
      )}
      {/* Starts hidden (data-hidden) so it doesn't flash in at the top
          of the page before the script syncs to the active section.
          nav-sd.ts removes the attribute once the user scrolls past the
          first section, re-adds it when they return to the top.
          Two variants: full text on medium+, short text on mobile —
          swapped via display rules in _nav-sd.scss. */}
      <span class="nav-sd__project" data-nav-sd-project data-hidden>
        <span class="nav-sd__project-full">{centerLabel}</span>
        <span class="nav-sd__project-short">{centerLabelShort}</span>
      </span>
      <button
        class="nav-sd__toggle btn-secondary"
        type="button"
        aria-expanded="false"
        aria-controls="nav-sd-menu"
        data-nav-sd-toggle
      >
        <span class="nav-sd__section-label">
          <span class="nav-sd__section-label-track" data-nav-sd-active-label>
            <span class="nav-sd__section-label-item">{defaultActiveLabel}</span>
          </span>
        </span>
        <IconChevronDown class="nav-sd__chevron" />
      </button>
    </div>
    <div
      id="nav-sd-menu"
      class="nav-sd__menu"
      hidden
      data-nav-sd-menu
    >
      <div class="nav-sd__menu-group">
        {flatSections.map((s) => (
          <a
            class="nav-sd__link"
            href={`#${s.id}`}
            data-section-id={s.id}
            data-label={s.label}
            data-depth={s.depth || null}
          >
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
)}

<script>
  import { initNavSd } from '../scripts/nav-sd';

  document.addEventListener('astro:page-load', () => {
    initNavSd();
  });
</script>
