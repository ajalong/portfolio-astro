---
import '../styles/global.scss';
import { ClientRouter } from 'astro:transitions';
import Background from '../components/Background.astro';
import ProgressiveBlur from '../components/ProgressiveBlur.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  bodyClass?: string;
  brandPrimary?: string;
  brandSecondary?: string;
  // og:type — 'website' for the home/index, 'article' for case studies.
  // Defaults to 'website' so existing callers are unaffected.
  pageType?: 'website' | 'article';
  // Optional JSON-LD structured data — a single schema.org object or an
  // array of them. Rendered as <script type="application/ld+json"> in head.
  jsonLd?: unknown;
}

const { title, description, image, url, bodyClass, brandPrimary, brandSecondary, pageType = 'website', jsonLd } = Astro.props as Props;

const siteName = 'Alan Long';
const pageTitle = title === siteName ? title : `${title} – ${siteName}`;
const site = Astro.site ? new URL(Astro.site) : new URL(Astro.url.origin);
const canonicalUrl = url ?? new URL(Astro.url.pathname, site).toString();

// Default social-share image for pages that don't pass their own (e.g. the
// homepage). A 1200×630 face-cropped headshot off the existing Cloudinary
// asset — gives link unfurls a branded card instead of a bare text preview.
// Pages with a real `image` prop (project pages pass their thumbnail) override
// this. Only the default's dimensions are known/fixed, so og:image:width/height
// are emitted just for it.
const DEFAULT_OG_IMAGE =
  'https://res.cloudinary.com/ajalong/image/upload/c_fill,g_face,w_1200,h_630,f_auto,q_auto:good/alan.design/headshot-edited.jpg';
const usingDefaultImage = !image;
const shareImage = image ?? DEFAULT_OG_IMAGE;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://www.clarity.ms" />

    {/* Preload the Regular woff2 — every page uses body-weight Graphik
        for almost all visible copy. Without the preload the font loads
        only after CSS parses, producing a brief FOUT on first paint. */}
    <link
      rel="preload"
      href="/Graphik-Regular-Cy-Gr-Web.89bcdd78.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Alan Long" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#222222" />
    <meta name="msapplication-TileColor" content="#222222" />
    <meta name="theme-color" content="#ffffff" />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:alt" content={title} />
    {usingDefaultImage && <meta property="og:image:width" content="1200" />}
    {usingDefaultImage && <meta property="og:image:height" content="630" />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="twitter:image:alt" content={title} />

    {jsonLd && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    )}

    <ClientRouter />

    {/* Microsoft Clarity — deferred until after the page is interactive.
        Loading it earlier puts the third-party script in the critical path
        and lights up its beacon traffic during initial paint; gating on
        `load` keeps the main thread free for the first interaction. */}
    <script is:inline type="text/javascript">
      window.addEventListener('load', function () {
        (function (c, l, a, r, i, t, y) {
          c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments) };
          t = l.createElement(r); t.async = 1;
          t.src = "https://www.clarity.ms/tag/" + i;
          y = l.getElementsByTagName(r)[0];
          y.parentNode.insertBefore(t, y);
        })(window, document, "clarity", "script", "w8iouo87v0");
      }, { once: true });
    </script>
  </head>
  <body
    class={`initial-load ${bodyClass ?? ''}`.trim()}
    style={brandPrimary && brandSecondary
      ? `--brand-primary: ${brandPrimary}; --brand-secondary: ${brandSecondary};`
      : undefined}
  >
    {/* Keyboard-only skip link — hidden visually until focused, then
        becomes a focusable affordance that jumps past the fixed top
        nav straight to <main>. Standard a11y pattern. */}
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Background />
    <ProgressiveBlur />
    <slot />
    <script>
      import { initThumbnailVideoHover } from '../scripts/thumbnail-video-hover';
      import { initMediaAutoplay } from '../scripts/media-autoplay';
      import { initPageWipe } from '../scripts/page-wipe';

      // Page-wipe binds module-level event listeners — call once on first load,
      // not inside astro:page-load (would re-bind on every navigation).
      initPageWipe();

      // Clear stuck focus before a ClientRouter navigation. Without this, a
      // tap on a project card can leave it in :focus-visible after navigating
      // back, pinning .item-cta / .item-meta visible on the homepage.
      document.addEventListener('astro:before-preparation', () => {
        const active = document.activeElement as HTMLElement | null;
        if (active && active !== document.body) active.blur();
      });

      document.addEventListener('astro:after-swap', () => {
        document.body.classList.remove('initial-load');

        document.querySelectorAll<HTMLVideoElement>('video').forEach((v) => {
          const src = v.getAttribute('src');
          if (src) {
            v.src = src;
          }
        });
      });

      document.addEventListener('astro:page-load', () => {
        initThumbnailVideoHover();
        initMediaAutoplay();

        document.querySelectorAll<HTMLImageElement>(
          '.media-full img, .thumbnail img'
        ).forEach((img) => {
          if (img.complete) {
            img.classList.add('is-loaded');
          } else {
            img.addEventListener('load', () => img.classList.add('is-loaded'), { once: true });
          }
        });
        // Note: no manual play() loop here — initMediaAutoplay's
        // IntersectionObserver fires synchronously on observe() with the
        // initial state, so visible-on-load videos start immediately.
      });
    </script>
  </body>
</html>

