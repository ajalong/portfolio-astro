---
import BaseLayout from './BaseLayout.astro';
import ProjectTeamPanel from '../components/ProjectTeamPanel.astro';
import ProjectNavbar from '../components/ProjectNavbar.astro';
import ProjectSectionIndex from '../components/ProjectSectionIndex.astro';
import ProjectCard from '../components/ProjectCard.astro';

interface NextProjectCard {
  href: string;
  title: string;
  client: string;
  summary: string;
  thumbnailSrc: string;
  thumbnailVideo?: string;
  thumbnailAlt: string;
}

interface TeamMember {
  name: string;
  role: string;
  headshot: string;
  description?: string;
}

interface SectionIndexEntry {
  id: string;
  label: string;
}

interface Props {
  title: string;
  client: string;
  description: string;
  image?: string;
  url?: string;
  otherWork?: NextProjectCard[];
  team?: TeamMember[];
  year?: number;
  sector?: string;
  sectionIndex?: SectionIndexEntry[];
  roleSummary?: string;
}

const { title, client, description, image, url, otherWork, team, year, sector, sectionIndex, roleSummary } = Astro.props as Props;
const clientWithYear = client;
const showTeamPanel = team && team.length > 0;
const showSectionIndex = sectionIndex && sectionIndex.length > 0;
---
<BaseLayout {title} description={description} {image} url={url} bodyClass="project-page">
  {!showSectionIndex && <ProjectNavbar internalEntryOnly />}
  <div class="page_container">
    <header>
      <div class="profile-header">
        <div class="profile-info">
          <div class="display-name">
            <h1>{title}</h1>
          </div>
          <p>{clientWithYear}</p>
        </div>
      </div>
    </header>
    {showSectionIndex && <ProjectSectionIndex sections={sectionIndex} />}
    <main>
      {showTeamPanel && <ProjectTeamPanel team={team} {roleSummary} />}
      <slot />
    </main>
    <footer id="page-permalink-footer">
      <div class="footer-content">
        {otherWork && otherWork.length > 0 && (
          <section class="other-work" aria-label="Other work">
            <p class="kicker">Other work</p>
            <div class="other-work__grid">
              {otherWork.map((p) => (
                <ProjectCard
                  href={p.href}
                  thumbnailSrc={p.thumbnailSrc}
                  thumbnailVideo={p.thumbnailVideo}
                  thumbnailAlt={p.thumbnailAlt}
                  projectTitle={p.title}
                  client={p.client}
                  summary={p.summary}
                />
              ))}
            </div>
          </section>
        )}
        <div class="page-nav-buttons">
          <div>
            <a href="/">See all work</a>
          </div>
        </div>
      </div>
    </footer>
  </div>
  <dialog class="media-lightbox" data-media-lightbox aria-label="Expanded media">
    <div class="media-lightbox__content" data-media-lightbox-content></div>
  </dialog>
  <script>
    import { initProjectNavFromInternal } from '../scripts/project-nav-visibility';
    import { initCaptionFade } from '../scripts/caption-fade';
    import { initMediaLightbox } from '../scripts/media-lightbox';
    // initMediaAutoplay moved to BaseLayout so home thumbnails benefit too.
    document.addEventListener('astro:page-load', () => {
      initProjectNavFromInternal();
      initCaptionFade();
      initMediaLightbox();
    });
  </script>
</BaseLayout>

