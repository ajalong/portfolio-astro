---
/**
 * 14Ă—14 left-pointing arrow. Stroke uses `currentColor` so the icon inherits
 * its parent's text colour â€” set `color` on a containing element to recolour.
 *
 * Path coordinates are the mirror of IconArrowRight around x=7. Kept as
 * explicit values (rather than a CSS scaleX flip on the right-pointing
 * source) so the SVG is semantically what its filename says.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props as Props;
---
<svg
  class={className}
  width="14"
  height="14"
  viewBox="0 0 14 14"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path d="M12.6063 7H1.4062" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M5.59844 11.1998L1.3984 6.9998L5.59844 2.7998" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
