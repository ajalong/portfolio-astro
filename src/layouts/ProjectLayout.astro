---
import BaseLayout from './BaseLayout.astro';
import ProjectTeamPanel from '../components/ProjectTeamPanel.astro';
import ProjectNavbar from '../components/ProjectNavbar.astro';
import ProjectSectionIndex from '../components/ProjectSectionIndex.astro';
import ProjectCard from '../components/ProjectCard.astro';

interface NextProjectCard {
  href: string;
  title: string;
  client: string;
  summary: string;
  thumbnailSrc: string;
  thumbnailVideo?: string;
  thumbnailAlt: string;
  brandPrimary?: string;
  brandSecondary?: string;
}

interface TeamMember {
  name: string;
  role: string;
  headshot: string;
  description?: string;
}

interface SectionIndexEntry {
  id: string;
  label: string;
}

interface Props {
  title: string;
  client: string;
  description: string;
  image?: string;
  url?: string;
  nextProject?: NextProjectCard;
  team?: TeamMember[];
  year?: number;
  sector?: string;
  sectionIndex?: SectionIndexEntry[];
  roleTitle?: string;
  roleSummary?: string;
  brandPrimary?: string;
  brandSecondary?: string;
}

const { title, client, description, image, url, nextProject, team, year, sector, sectionIndex, roleTitle, roleSummary, brandPrimary, brandSecondary } = Astro.props as Props;
const clientWithYear = client;
const showTeamPanel = team && team.length > 0;
const showSectionIndex = sectionIndex && sectionIndex.length > 0;
---
<BaseLayout {title} description={description} {image} url={url} bodyClass="project-page" {brandPrimary} {brandSecondary}>
  {!showSectionIndex && <ProjectNavbar internalEntryOnly />}
  <div class="page_container">
    <header>
      <div class="profile-header">
        <div class="profile-info">
          <div class="display-name">
            <h1>{title}</h1>
          </div>
          <p>{clientWithYear}</p>
        </div>
      </div>
    </header>
    {showSectionIndex && <ProjectSectionIndex sections={sectionIndex} />}
    <main>
      {showTeamPanel && <ProjectTeamPanel team={team} {roleTitle} {roleSummary} />}
      <slot />
    </main>
    <footer id="page-permalink-footer">
      <div class="footer-content">
        {nextProject && (
          <section class="next-project" aria-label="Next project">
            <p class="kicker">Next</p>
            <div
              data-next-project-brand
              data-brand-primary={nextProject.brandPrimary}
              data-brand-secondary={nextProject.brandSecondary}
            >
              <ProjectCard
                href={nextProject.href}
                thumbnailSrc={nextProject.thumbnailSrc}
                thumbnailVideo={nextProject.thumbnailVideo}
                thumbnailAlt={nextProject.thumbnailAlt}
                projectTitle={nextProject.title}
                client={nextProject.client}
                summary={nextProject.summary}
                belowFold
              />
            </div>
          </section>
        )}
        <div class="page-nav-buttons">
          <div>
            <a href="/">See all work</a>
          </div>
        </div>
      </div>
    </footer>
  </div>
  <dialog class="media-lightbox" data-media-lightbox aria-label="Expanded media">
    <div class="media-lightbox__content" data-media-lightbox-content></div>
  </dialog>
  <script>
    import { initProjectNavFromInternal } from '../scripts/project-nav-visibility';
    import { initCaptionFade } from '../scripts/caption-fade';
    import { initMediaLightbox } from '../scripts/media-lightbox';
    import { initNextProjectBrandSwap } from '../scripts/next-project-brand-swap';
    // initMediaAutoplay moved to BaseLayout so home thumbnails benefit too.
    document.addEventListener('astro:page-load', () => {
      initProjectNavFromInternal();
      initCaptionFade();
      initMediaLightbox();
      initNextProjectBrandSwap();
    });
  </script>
</BaseLayout>

