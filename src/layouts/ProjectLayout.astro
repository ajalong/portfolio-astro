---
import BaseLayout from './BaseLayout.astro';
import ProjectTeamPanel from '../components/ProjectTeamPanel.astro';
import ProjectNavbar from '../components/ProjectNavbar.astro';
import NavLg from '../components/NavLg.astro';
import NavSd from '../components/NavSd.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import { resolveThumbnails } from '../lib/cloudinary.mjs';
import { PROJECT_THUMBNAIL_ALTS } from '../data/projectThumbnailAlts';

interface TeamMember {
  name: string;
  role: string;
  headshot: string;
  description?: string;
}

interface OrgEntry {
  name: string;
  caption: string;
  logo?: string;
  url?: string;
}

interface SectionIndexEntry {
  id: string;
  label: string;
}

interface Props {
  title: string;
  client: string;
  description: string;
  image?: string;
  url?: string;
  // Raw project collection entry — ProjectLayout decides whether to
  // render it as a full ProjectShowcase block (when the next project has
  // both impactMetrics and showcaseMedia) or as the small ProjectCard,
  // mirroring the homepage logic.
  nextProject?: any;
  team?: TeamMember[];
  orgs?: OrgEntry[];
  year?: number;
  sector?: string;
  industry?: string;
  theme?: string;
  sectionIndex?: SectionIndexEntry[];
  roleTitle?: string;
  roleSummary?: string;
  brandPrimary?: string;
  brandSecondary?: string;
}

const { title, client, description, image, url, nextProject, team, orgs, year, sector, industry, theme, sectionIndex, roleTitle, roleSummary, brandPrimary, brandSecondary } = Astro.props as Props;
const headerKickers = [industry, theme].filter(Boolean) as string[];
const showTeamPanel = team && team.length > 0;
const showSectionIndex = sectionIndex && sectionIndex.length > 0;

// Mirror the homepage's hasShowcase check so the next-project section
// uses the full ProjectShowcase block when the project has both
// impactMetrics and showcaseMedia, and falls back to the small ProjectCard
// otherwise.
const nextHasShowcase = !!(
  nextProject?.data?.impactMetrics?.length && nextProject?.data?.showcaseMedia
);

// Derive ProjectCard props for the fallback render. Skipped when the
// showcase variant is going to render — keeps the resolveThumbnails call
// out of the showcase path.
let nextProjectCard: {
  href: string;
  thumbnailSrc: string | null;
  thumbnailVideo?: string;
  thumbnailAlt: string;
  projectTitle: string;
  client: string;
  summary: string;
} | null = null;
if (nextProject && !nextHasShowcase) {
  const slug = nextProject.data.slug ?? nextProject.id;
  const thumbs = resolveThumbnails(nextProject.data);
  nextProjectCard = {
    href: `/project/${slug}`,
    thumbnailSrc: thumbs.poster,
    thumbnailVideo: thumbs.video ?? undefined,
    thumbnailAlt:
      PROJECT_THUMBNAIL_ALTS[slug] ?? `${nextProject.data.title} thumbnail`,
    projectTitle: nextProject.data.title,
    client: nextProject.data.client,
    summary: nextProject.data.summary,
  };
}
---
<BaseLayout {title} description={description} {image} url={url} bodyClass="project-page" {brandPrimary} {brandSecondary}>
  {!showSectionIndex && <ProjectNavbar internalEntryOnly />}
  <div class="page_container">
    <header>
      <div class="profile-header">
        <div class="profile-info">
          <div class="display-name">
            <h1 class="text-display">{title}</h1>
          </div>
          {headerKickers.length > 0 && (
            <p class="kicker project-header-kickers">
              {headerKickers.map((label) => <span>{label}</span>)}
            </p>
          )}
        </div>
      </div>
    </header>
    {showSectionIndex && (
      <>
        <NavLg sections={sectionIndex} />
        <NavSd sections={sectionIndex} centerLabelShort={client} />
      </>
    )}
    <main id="main-content">
      {showTeamPanel && <ProjectTeamPanel team={team} {orgs} {roleTitle} {roleSummary} />}
      <slot />
    </main>
    <footer id="page-permalink-footer">
      <div class="footer-content">
        {nextProject && (
          <section class="next-project" aria-label="Next project">
            <p class="kicker">Next</p>
            <div
              data-next-project-brand
              data-brand-primary={nextProject.data?.brand?.primary}
              data-brand-secondary={nextProject.data?.brand?.secondary}
            >
              {nextHasShowcase ? (
                <ProjectShowcase project={nextProject} />
              ) : nextProjectCard ? (
                <ProjectCard
                  href={nextProjectCard.href}
                  thumbnailSrc={nextProjectCard.thumbnailSrc}
                  thumbnailVideo={nextProjectCard.thumbnailVideo}
                  thumbnailAlt={nextProjectCard.thumbnailAlt}
                  projectTitle={nextProjectCard.projectTitle}
                  client={nextProjectCard.client}
                  summary={nextProjectCard.summary}
                  belowFold
                />
              ) : null}
            </div>
          </section>
        )}
        <div class="page-nav-buttons">
          <div>
            <a href="/">See all work</a>
          </div>
        </div>
      </div>
    </footer>
  </div>
  <dialog class="media-lightbox" data-media-lightbox aria-label="Expanded media">
    <button
      class="media-lightbox__close btn-secondary"
      type="button"
      data-media-lightbox-close
      aria-label="Close"
    >
      Close
    </button>
    <div class="media-lightbox__content">
      <div class="media-lightbox__media" data-media-lightbox-media></div>
      <p class="media-lightbox__caption" data-media-lightbox-caption></p>
    </div>
  </dialog>
  <script>
    import { initProjectNavFromInternal } from '../scripts/project-nav-visibility';
    import { initCaptionFade } from '../scripts/caption-fade';
    import { initMediaLightbox } from '../scripts/media-lightbox';
    import { initNextProjectBrandSwap } from '../scripts/next-project-brand-swap';
    // initMediaAutoplay moved to BaseLayout so home thumbnails benefit too.
    document.addEventListener('astro:page-load', () => {
      initProjectNavFromInternal();
      initCaptionFade();
      initMediaLightbox();
      initNextProjectBrandSwap();
    });
  </script>
</BaseLayout>

