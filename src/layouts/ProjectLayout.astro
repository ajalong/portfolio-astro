---
import BaseLayout from './BaseLayout.astro';
import ProjectTeamPanel from '../components/ProjectTeamPanel.astro';
import ProjectNavbar from '../components/ProjectNavbar.astro';
import ProjectSectionIndex from '../components/ProjectSectionIndex.astro';

interface PivotProps {
  href: string;
  title: string;
  snippet: string;
  thumbnailSrc?: string;
  thumbnailAlt?: string;
}

interface TeamMember {
  name: string;
  role: string;
  headshot: string;
  description?: string;
}

interface SectionIndexEntry {
  id: string;
  label: string;
}

interface Props {
  title: string;
  client: string;
  description: string;
  image?: string;
  url?: string;
  pivot?: PivotProps;
  team?: TeamMember[];
  year?: number;
  sector?: string;
  sectionIndex?: SectionIndexEntry[];
}

const { title, client, description, image, url, pivot, team, year, sector, sectionIndex } = Astro.props as Props;
const clientWithYear = [client, year].filter(Boolean).join(' – ');
const showTeamPanel = team && team.length > 0;
const showSectionIndex = sectionIndex && sectionIndex.length > 0;
---
<BaseLayout {title} description={description} {image} url={url} bodyClass="project-page">
  {!showSectionIndex && <ProjectNavbar internalEntryOnly />}
  <div class="page_container">
    <header>
      <div class="profile-header">
        <div class="profile-info">
          <div class="display-name">
            <h1>{title}</h1>
          </div>
          <p>{clientWithYear}</p>
        </div>
      </div>
    </header>
    {showSectionIndex && <ProjectSectionIndex sections={sectionIndex} />}
    <main>
      {showTeamPanel && <ProjectTeamPanel team={team} />}
      <slot />
    </main>
    <footer id="page-permalink-footer">
      <div class="footer-content">
        {pivot && (
          <div id="pivot">
            <div class="pivot-link">
              <a href={pivot.href}>
                <div class="pages-attachment">
                  {pivot.thumbnailSrc && (
                    <div class="pages-thumbnail">
                      <img src={pivot.thumbnailSrc} alt={pivot.thumbnailAlt ?? ''} />
                    </div>
                  )}
                  <div class="page-info">
                    <div class="page-title">{pivot.title}</div>
                    <div class="snippet">{pivot.snippet}</div>
                  </div>
                </div>
              </a>
            </div>
          </div>
        )}
        <div class="page-nav-buttons">
          <div>
            <a href="/">See all work</a>
          </div>
        </div>
      </div>
    </footer>
  </div>
  <script>
    import { initProjectNavFromInternal } from '../scripts/project-nav-visibility';
    import { initCaptionFade } from '../scripts/caption-fade';
    import { initMediaAutoplay } from '../scripts/media-autoplay';
    document.addEventListener('astro:page-load', () => {
      initProjectNavFromInternal();
      initCaptionFade();
      initMediaAutoplay();
    });
  </script>
</BaseLayout>

