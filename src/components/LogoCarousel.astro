---
/**
 * Auto-scrolling logo marquee. Full-colour SVG logos that loop
 * horizontally — pauses on hover; while paused the user can drag the
 * track horizontally to scrub through logos at their own pace.
 *
 * Authoring:
 *   <LogoCarousel logos={homeLogos} />
 *
 * Source-of-truth lives in `src/data/homeLogos.ts` (typed standalone
 * list, independent of the projects collection). Each `src` is a path
 * under `public/` (e.g. `/logos/gsk.svg`). SVG is vector-perfect at
 * any size, so the CSS `height: 32px` on the `<img>` controls render
 * size with no source-side processing needed.
 *
 * Rendering:
 *   - SSR emits ONE set of logos. The init script (logo-carousel.ts)
 *     measures the original set against the container and clones the
 *     items as many times as needed for the track to exceed 2× the
 *     container width — without that, sparse logo lists leave the
 *     carousel half-empty mid-loop. The animation translates by the
 *     measured single-set width plus one inter-item gap (the seamless
 *     repeat distance) so each loop lands on a visually identical
 *     position with no sideways snap.
 *   - Edges fade via a mask-image on the wrapper so logos slide in/out
 *     of view rather than appearing/disappearing at hard edges.
 *
 * Page-scroll safety:
 *   - The carousel doesn't capture wheel events, so vertical page
 *     scroll always passes through.
 *   - `touch-action: pan-y` on the wrapper hands vertical touch to the
 *     page natively; horizontal touch fires pointer events the script
 *     interprets as drag-scroll (only while paused on hover).
 */
import type { HomeLogo } from '../data/homeLogos';

interface Props {
  logos: HomeLogo[];
  /** Optional accessible label for the carousel region. */
  ariaLabel?: string;
}

const {
  logos,
  ariaLabel = 'Selected clients and partners',
} = Astro.props as Props;

// Progressive blur stack for each edge — mirrors the page's top cap
// but oriented horizontally. Blur intensity rises from inner edge
// (fade region's inner extent) to outer edge (carousel's literal left
// or right edge), so logos approach the edge through progressively
// heavier blur, then dissolve into the card surface.
//
// `region` is in axis-relative %, where 0% = inner edge (transparent
// end) and 100% = outer edge (opaque end). The 1-2-4-8 radius ramp
// matches the cap; total compute scales with each layer's bounding
// box × kernel² (see _progressive-blur perf notes).
type EdgeLayer = {
  blur: number;
  region: { inner: number; outer: number };
  stops: Array<{ pos: number; alpha: number }>;
};
const edgeLayers: EdgeLayer[] = [
  {
    blur: 1,
    region: { inner: 0, outer: 75 },
    stops: [
      { pos: 0,  alpha: 0 },
      { pos: 25, alpha: 1 },
      { pos: 50, alpha: 1 },
      { pos: 75, alpha: 0 },
    ],
  },
  {
    blur: 2,
    region: { inner: 25, outer: 100 },
    stops: [
      { pos: 25,  alpha: 0 },
      { pos: 50,  alpha: 1 },
      { pos: 75,  alpha: 1 },
      { pos: 100, alpha: 0 },
    ],
  },
  {
    blur: 4,
    region: { inner: 50, outer: 100 },
    stops: [
      { pos: 50,  alpha: 0 },
      { pos: 75,  alpha: 1 },
      { pos: 100, alpha: 1 },
    ],
  },
  {
    blur: 8,
    region: { inner: 75, outer: 100 },
    stops: [
      { pos: 75,  alpha: 0 },
      { pos: 100, alpha: 1 },
    ],
  },
];

function edgeMaskGradient(layer: EdgeLayer, side: 'left' | 'right'): string {
  // Mask alpha is computed in axis-relative %; rescale to layer-
  // relative % so the stops land at the right positions inside the
  // layer's bounding box.
  const span = layer.region.outer - layer.region.inner;
  const segments = layer.stops.map((s) => {
    const layerPct = ((s.pos - layer.region.inner) / span) * 100;
    return `rgba(0,0,0,${s.alpha}) ${layerPct.toFixed(2)}%`;
  }).join(', ');
  // Direction puts the "outer end" of the gradient at the wrapper's
  // outer edge — `to left` on the left edge, `to right` on the right.
  const direction = side === 'left' ? 'to left' : 'to right';
  return `linear-gradient(${direction}, ${segments})`;
}

function edgeLayerStyle(layer: EdgeLayer, side: 'left' | 'right'): string {
  // Position the layer to its axis-relative region inside the 80px
  // edge wrapper. For the LEFT edge wrapper, wrapper x=0 is the
  // outer edge (page-left), so a layer covering axis 0–75% (inner
  // 75%) sits at wrapper x=25–100%. For the RIGHT edge wrapper,
  // wrapper x=0 is the inner edge (page-center side), so the same
  // axis 0–75% layer sits at wrapper x=0–75%.
  const insetA = side === 'left' ? 100 - layer.region.outer : layer.region.inner;
  const insetB = side === 'left' ? layer.region.inner : 100 - layer.region.outer;
  const mask = edgeMaskGradient(layer, side);
  return [
    `left: ${insetA}%`,
    `right: ${insetB}%`,
    `backdrop-filter: blur(${layer.blur}px)`,
    `-webkit-backdrop-filter: blur(${layer.blur}px)`,
    `mask-image: ${mask}`,
    `-webkit-mask-image: ${mask}`,
  ].join('; ');
}

// SSR emits one canonical set; the init script clones as many copies
// as it needs at runtime once it has the container's measured width.
// Cloned items are marked aria-hidden by the script so screen readers
// only announce each logo once.
---

{logos.length > 0 && (
  <div class="logo-carousel" data-logo-carousel role="region" aria-label={ariaLabel}>
    <ul class="logo-carousel__track" data-logo-carousel-track>
      {logos.map((logo) => (
        <li class="logo-carousel__item">
          <img
            src={logo.src}
            alt={logo.name}
            loading="lazy"
            decoding="async"
            draggable="false"
          />
        </li>
      ))}
    </ul>
    {/* Progressive-blur edges. Each side has 4 stacked layers with
        increasing blur radii (1-2-4-8) anchored to the outer side; the
        ::after on the wrapper carries the white-tint gradient over
        the blur stack, mirroring the page's top cap. */}
    {(['left', 'right'] as const).map((side) => (
      <div class={`logo-carousel__edge logo-carousel__edge--${side}`} aria-hidden="true">
        {edgeLayers.map((layer) => (
          <div class="logo-carousel__edge-layer" style={edgeLayerStyle(layer, side)} />
        ))}
      </div>
    ))}
  </div>
)}

<script>
  import { initLogoCarousels } from '../scripts/logo-carousel';
  document.addEventListener('astro:page-load', () => {
    initLogoCarousels();
  });
</script>
