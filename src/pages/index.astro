---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROJECT_THUMBNAIL_ALTS } from '../data/projectThumbnailAlts';
import { getLastUpdatedLabel } from '../data/lastUpdated';
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import HomeSectionIndex from '../components/HomeSectionIndex.astro';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.data.published !== false)
  .sort((a, b) => a.data.order - b.data.order);

// Each project card needs a stable DOM id so the sticky nav's jump-links
// can target it. Prefix to avoid clashes with any other ids on the page.
const navProjects = projects.map((p) => ({
  id: `project-${p.slug}`,
  label: p.data.client,
}));

const subtitle = getLastUpdatedLabel();
---
<BaseLayout
  title="Alan Long"
  description="UI/UX designer and front-end developer. Former member of Interbrand's design team and led design and development at Cheerful Twentyfirst."
  bodyClass="home"
>
  <div class="page_container">
    <header>
      <div class="profile-info">
        <div class="display-name">
          <h1>Alan Long</h1>
        </div>
        <p>Product Design</p>
      </div>
      <div class="about">
        <p>
          Five years at agencies in London, with clients across pharma, automotive, engineering and media. Brand skills from my time at <a href="https://interbrand.com/" target="_blank" rel="noopener noreferrer">Interbrand</a>, and a front-end background that keeps me close to implementation. Both feed a systems-led approach to design that runs from high-level architectural choices through to visual craft.
        </p>
      </div>
    </header>
    <HomeSectionIndex projects={navProjects} subtitle={subtitle} />
    <main>
      <ul class="project-list" id="work">
        {
          projects.map((project) => (
            <li id={`project-${project.slug}`}>
              <ProjectCard
                href={`/project/${project.slug}`}
                thumbnailSrc={project.data.thumbnailImage}
                thumbnailAlt={
                  PROJECT_THUMBNAIL_ALTS[project.slug] ?? `${project.data.title} thumbnail`
                }
                thumbnailVideo={project.data.thumbnailVideo}
                projectTitle={project.data.title}
                client={project.data.client}
                summary={project.data.summary}
              />
            </li>
          ))
        }
      </ul>
    </main>
  </div>
</BaseLayout>
