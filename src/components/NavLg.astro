---
/**
 * Sticky jump-to-section navigator shown on project pages that opt in.
 *
 * Each entry links to an `id` on a section within the article. Active-state
 * tracking is handled in nav-lg.ts via IntersectionObserver.
 *
 * Heading group mirrors the home page's HomeSectionIndex: a permalink line
 * + an "Updated <Month> <Year>" subtitle from the most recent commit (via
 * `getLastUpdatedLabel()`). No back link here — the persistent "Back" in
 * the top-left of the page (NavSd, visible at every viewport) handles
 * the return-to-/ affordance.
 */

import { getLastUpdatedLabel } from '../data/lastUpdated';

interface SectionEntry {
  id: string;
  label: string;
  children?: SectionEntry[];
}

interface Props {
  sections: SectionEntry[];
}

const { sections } = Astro.props as Props;
// "/project/gsk" → "alanlong.design/gsk"
const slug = Astro.url.pathname.replace(/^\/project\//, '');
const displayUrl = `alanlong.design/${slug}`;
const subtitle = getLastUpdatedLabel();

// Flatten the nested config into render order. Each entry carries its
// nesting depth so the template can apply indentation. Depth > 0 sets
// `data-nested` for CSS to indent.
type FlatEntry = SectionEntry & { depth: number };
function flatten(items: SectionEntry[], depth = 0, out: FlatEntry[] = []): FlatEntry[] {
  for (const it of items) {
    out.push({ id: it.id, label: it.label, depth });
    if (it.children?.length) flatten(it.children, depth + 1, out);
  }
  return out;
}
const flatSections = flatten(sections);
---

{sections && sections.length > 0 && (
  <nav
    class="nav-lg"
    aria-label="Case study sections"
    data-nav-lg
  >
    <div class="nav-lg__group">
      <span class="nav-lg__permalink">{displayUrl}</span>
      <span class="nav-lg__site-section">{subtitle}</span>
    </div>
    <div class="nav-lg__group">
      {flatSections.map((s) => (
        <a
          class="nav-lg__link"
          href={`#${s.id}`}
          data-section-id={s.id}
          data-label={s.label}
          data-depth={s.depth || null}
        >
          {s.label}
        </a>
      ))}
    </div>
    <div class="nav-lg__group nav-lg__contact">
      <a class="nav-lg__contact-link" href="/alanlong-resume.pdf" target="_blank" rel="noopener noreferrer">Resume.pdf<span class="sr-only"> (opens in new tab)</span></a>
      <a class="nav-lg__contact-link" href="mailto:alan@ajalong.com">alan@ajalong.com</a>
    </div>
  </nav>
)}

<script>
  import { initNavLg } from '../scripts/nav-lg';

  document.addEventListener('astro:page-load', () => {
    initNavLg();
  });
</script>
