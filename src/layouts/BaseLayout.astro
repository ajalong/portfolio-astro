---
import '../styles/global.scss';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  bodyClass?: string;
}

const { title, description, image, url, bodyClass } = Astro.props as Props;

const siteName = 'Alan Long';
const pageTitle = title === siteName ? title : `${title} – ${siteName}`;
const site = Astro.site ? new URL(Astro.site) : new URL(Astro.url.origin);
const canonicalUrl = url ?? new URL(Astro.url.pathname, site).toString();
---
<html lang="en">
  <head>
    <!-- Safari only: mesh without SVG filter (see `.safari-mesh-fallback` in global.scss). iOS Chrome has “Safari” in UA too — exclude Chromium family. -->
    <script is:inline>
      (function () {
        var ua = navigator.userAgent;
        if (!/safari/i.test(ua)) return;
        if (/chrom(e|ium)|crios|fxios|edg\/|opr\/|opr\s|android.*wv/i.test(ua)) return;
        document.documentElement.classList.add('safari-mesh-fallback');
      })();
    </script>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://www.clarity.ms" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Alan Long" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#222222" />
    <meta name="msapplication-TileColor" content="#222222" />
    <!-- Same hex as --browser-chrome-hairline (global.scss): Safari’s toolbar isn’t #fff; this tints UI to meet the page -->
    <meta name="theme-color" content="#ebebeb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#ebebeb" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    {image && <meta property="og:image:alt" content={title} />}

    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <ClientRouter />
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "w8iouo87v0");
    </script>
  </head>
  <body class={`initial-load ${bodyClass ?? ''}`.trim()}>
    <svg
      width="1"
      height="1"
      aria-hidden="true"
      focusable="false"
      style="position: fixed; left: -9999px; top: 0; overflow: hidden"
    >
      <defs>
        <!-- Grain via displacement (no feBlend — it was re-compositing SourceGraphic and killing dither). -->
        <!-- Region 0/0/1/1 = full bbox (objectBoundingBox). Keep scale modest — large values + clip-path can blank WebKit. -->
        <filter id="page-mesh-grain" color-interpolation-filters="sRGB" x="0" y="0" width="1" height="1">
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.88"
            numOctaves="3"
            stitchTiles="stitch"
            result="grain"
          />
          <feDisplacementMap in="SourceGraphic" in2="grain" scale="52" xChannelSelector="R" />
        </filter>
        <linearGradient
          id="btn-border-ring-iridescent"
          gradientUnits="objectBoundingBox"
          x1="0"
          y1="1"
          x2="1"
          y2="0"
        >
          <stop offset="0%" stop-color="#f6f7f8" />
          <stop offset="11%" stop-color="#ebe7f3" />
          <stop offset="22%" stop-color="#ddd2ea" />
          <stop offset="33%" stop-color="#e2c8d8" />
          <stop offset="44%" stop-color="#d4c0c8" />
          <stop offset="55%" stop-color="#a894a8" />
          <stop offset="66%" stop-color="#8f7488" />
          <stop offset="77%" stop-color="#9b86ac" />
          <stop offset="88%" stop-color="#e2e0ee" />
          <stop offset="100%" stop-color="#f6f7f8" />
        </linearGradient>
      </defs>
    </svg>
    <!-- Fixed top white wash: must be real DOM (not html::after) so it stacks above <main> inside body’s isolated context. -->
    <div class="page-top-fade" aria-hidden="true"></div>
    <slot />
    <script>
      import { initButtonBorderRings } from '../scripts/border-ring';
      import { initThumbnailVideoHover } from '../scripts/thumbnail-video-hover';
      import { initMediaAutoplay } from '../scripts/media-autoplay';

      document.addEventListener('astro:after-swap', () => {
        document.body.classList.remove('initial-load');

        document.querySelectorAll<HTMLVideoElement>('video').forEach((v) => {
          const src = v.getAttribute('src');
          if (src) {
            v.src = src;
          }
        });
      });

      document.addEventListener('astro:page-load', () => {
        initButtonBorderRings();
        initThumbnailVideoHover();
        initMediaAutoplay();

        document.querySelectorAll<HTMLImageElement>(
          '.media-full img, .media-half img, .thumbnail img'
        ).forEach((img) => {
          if (img.complete) {
            img.classList.add('is-loaded');
          } else {
            img.addEventListener('load', () => img.classList.add('is-loaded'), { once: true });
          }
        });
        // Note: no manual play() loop here — initMediaAutoplay's
        // IntersectionObserver fires synchronously on observe() with the
        // initial state, so visible-on-load videos start immediately.
      });
    </script>
  </body>
</html>

