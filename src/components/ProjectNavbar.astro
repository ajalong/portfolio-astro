---
import ButtonBorderRing from './ButtonBorderRing.astro';

interface Props {
  href?: string;
  ariaLabel?: string;
  /** When true (project pages), hidden until client confirms same-origin referrer */
  internalEntryOnly?: boolean;
}

const {
  href = '/',
  ariaLabel = 'Back to home',
  internalEntryOnly = false,
} = Astro.props as Props;
---
<a
  href={href}
  class:list={[
    'project-nav-btn',
    { 'project-nav-btn--deferred': internalEntryOnly },
  ]}
  aria-label={ariaLabel}
  data-internal-entry-only={internalEntryOnly ? '' : undefined}
>
  <ButtonBorderRing />
  <svg
    class="project-nav-btn__icon"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M3 12H21"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
    <path
      d="M3 6H21"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
    <path
      d="M3 18H21"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</a>
