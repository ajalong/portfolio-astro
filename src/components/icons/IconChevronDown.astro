---
/**
 * 14×14 down-pointing chevron. Stroke uses `currentColor` so the icon inherits
 * its parent's text colour — set `color` on a containing element to recolour.
 *
 * Source asset: ~/Documents/Portfolio/icons/chevron.svg (canonical).
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props as Props;
---
<svg
  class={className}
  width="14"
  height="14"
  viewBox="0 0 14 14"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
