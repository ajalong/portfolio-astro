---
/**
 * Progressive blur cap — frosted-glass effect at the top of the viewport
 * for content scrolling underneath. Stacks N backdrop-filter layers with
 * doubling blur radii, each masked to an overlapping horizontal slice
 * via linear-gradient. Net effect: a perceptually smooth Gaussian
 * falloff from heavy blur at the top edge to ~zero at the bottom edge.
 *
 * Why N layers, not one with a single mask:
 * A single backdrop-filter + mask gives a hard halo at the mask edge
 * (blur intensity is binary inside the mask, only opacity varies).
 * Doubling N times and overlapping the slices approximates a continuous
 * Gaussian curve and eliminates the halo.
 *
 * Performance:
 *   - 8 backdrop-filter layers is GPU-heavy. The smallest radii
 *     (≤0.5px) are nearly free; 5px/10px dominate cost. `contain:
 *     layout paint` on the wrapper scopes repaints.
 *   - `prefers-reduced-transparency: reduce` collapses the stack to a
 *     single linear-gradient fade with no blur — cheap and accessible.
 *
 * Mask percentages are relative to the component's height, not the
 * viewport — so the height prop is what shifts where the falloff lands.
 */
interface Props {
  height?: string;
  // Optional extra class on the wrapper — lets a caller override the
  // default fixed-to-viewport positioning, e.g. mount the cap inside a
  // card chrome with `position: absolute`.
  class?: string;
}
// Default height tracks `--cap-height` (defined in _tokens.scss) so the
// cap ends at the page title's top at scroll=0 — content scrolling past
// blurs progressively; the title stays clear on initial load. Callers
// can still pass an explicit height to override (e.g. mounting the cap
// inside a card chrome with a fixed dimension).
const { height = 'var(--cap-height)', class: className } = Astro.props as Props;

// Layer table.
//
// Sizing optimisation (idea A in the perf analysis): each layer is
// positioned to span only the cap-region where its mask is non-zero,
// instead of `inset: 0`. `backdrop-filter` blurs the layer's full
// bounding box regardless of mask alpha — the mask just hides results,
// it doesn't reduce compute. Sizing layers to their visible regions
// therefore cuts blur work proportionally with no visual change.
//
// Net blur area per frame: 225% of cap area (75+75+50+25), down from
// 400% with the previous 4-layer full-extent stack — ~44% reduction.
//
// Earlier we also trimmed layers at 80% of cap (idea B) and dropped
// the heaviest layer, on the bet that the ::after tint would hide the
// blur cutoff. Visually it didn't — the blur-stop seam was readable.
// Rolled back: layers now extend to where their masks were naturally
// zero, no artificial trim.
//
// Blur radii follow a 1-2-4-8 geometric ramp (2× per step). Earlier
// we tried 1-3-6-12 for a more dramatic top blur, but L4 dominated
// the cost (kernel area scales quadratically — 12² = 144 vs 8² = 64,
// 56% more work per pixel). The 1-2-4-8 ramp keeps a geometric
// progression with each step visibly different from the last, while
// halving the heaviest layer's per-pixel cost. Net per-frame blur
// compute roughly 55% of the 1-3-6-12 variant.
//
// Each layer's `region` is its CAP-relative band ({bottom, top} in %
// from the cap's bottom edge). `stops` are also in cap coordinates so
// they read naturally against the visual; the mask generator rescales
// them to layer-relative percentages when emitting the gradient.

type Layer = {
  blur: number;
  region: { bottom: number; top: number };
  stops: Array<{ pos: number; alpha: number }>;
};
const layers: Layer[] = [
  {
    blur: 1,
    region: { bottom: 0, top: 75 },
    stops: [
      { pos: 0,  alpha: 0 },
      { pos: 25, alpha: 1 },
      { pos: 50, alpha: 1 },
      { pos: 75, alpha: 0 },
    ],
  },
  {
    blur: 2,
    region: { bottom: 25, top: 100 },
    stops: [
      { pos: 25,  alpha: 0 },
      { pos: 50,  alpha: 1 },
      { pos: 75,  alpha: 1 },
      { pos: 100, alpha: 0 },
    ],
  },
  {
    blur: 4,
    region: { bottom: 50, top: 100 },
    stops: [
      { pos: 50,  alpha: 0 },
      { pos: 75,  alpha: 1 },
      { pos: 100, alpha: 1 },
    ],
  },
  {
    blur: 8,
    region: { bottom: 75, top: 100 },
    stops: [
      { pos: 75,  alpha: 0 },
      { pos: 100, alpha: 1 },
    ],
  },
];

function maskGradient(layer: Layer): string {
  const span = layer.region.top - layer.region.bottom;
  const segments = layer.stops.map((s) => {
    const layerPct = ((s.pos - layer.region.bottom) / span) * 100;
    return `rgba(0,0,0,${s.alpha}) ${layerPct.toFixed(2)}%`;
  }).join(', ');
  return `linear-gradient(to top, ${segments})`;
}
---

<div class:list={['progressive-blur', className]} style={`--pb-height: ${height};`} aria-hidden="true">
  {layers.map((l, i) => {
    const mask = maskGradient(l);
    // Position the layer to its cap-relative region. `bottom` and
    // `top` are inset values: `bottom: 0%` anchors to the cap bottom;
    // `top: 25%` leaves the top 25% of the cap empty. backdrop-filter
    // only samples and blurs within the layer's bounding box.
    const bottomInset = l.region.bottom;
    const topInset = 100 - l.region.top;
    return (
      <div
        class="progressive-blur__layer"
        style={`z-index: ${i + 1}; left: 0; right: 0; bottom: ${bottomInset}%; top: ${topInset}%; backdrop-filter: blur(${l.blur}px); -webkit-backdrop-filter: blur(${l.blur}px); mask-image: ${mask}; -webkit-mask-image: ${mask};`}
      />
    );
  })}
</div>
