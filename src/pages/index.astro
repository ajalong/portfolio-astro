---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROJECT_THUMBNAIL_ALTS } from '../data/projectThumbnailAlts';
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import ButtonBorderRing from '../components/ButtonBorderRing.astro';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.data.published !== false)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Alan Long"
  description="For the last year I've been travelling the world. Previously I was part of Interbrand's design team and led design and development at Cheerful Twentyfirst."
  bodyClass="home"
>
  <main>
    <div class="left">
      <div>
        <div class="profile-header">
          <div class="profile-photo-wrap">
            <div class="profile-photo">
              <img
                draggable="false"
                alt="Headshot of Alan Long"
                src="https://res.cloudinary.com/ajalong/image/upload/c_fill,h_92,w_92,dpr_2.0,f_auto,q_auto:best/alan.design/headshot-edited.jpg"
              />
            </div>
          </div>
          <div class="profile-info">
            <div class="display-name">
              <h1>Alan Long</h1>
            </div>
            <p>UI/UX design</p>
          </div>
          <div class="profile-social cta">
            <a
              class="cta__link cta__link--secondary"
              href="https://linkedin.com/in/alanalberglong"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <ButtonBorderRing />
              <svg
                class="cta__icon-svg"
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  fill="currentColor"
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                />
              </svg>
            </a>
            <a
              class="cta__link cta__link--secondary"
              href="https://dribbble.com/alalo"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Dribbble"
            >
              <ButtonBorderRing />
              <img src="/dribbble.svg" alt="" aria-hidden="true" />
            </a>
          </div>
        </div>
        <section>
          <div class="about">
            <p>
              I have been a member of <a href="https://interbrand.com/" target="_blank">Interbrand’s</a> design team and led the design and development of digital platforms at <a href="https://cheerfultwentyfirst.com/" target="_blank">Cheerful Twentyfirst</a>. For the last year I’ve been travelling the world.
            </p>
          </div>
        </section>
      </div>
      <section class="cta" aria-label="Contact">
        <div class="cta-stack">
          <a
            class="cta__link u-pill-primary"
            href="mailto:alan@ajalong.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            <ButtonBorderRing />
            <div>
              <img src="/mail.svg" alt="" aria-hidden="true" />
              <span>Email me</span>
            </div>
          </a>
          <a
            class="cta__link u-pill-primary"
            href="/Alan-Long-Resume-2026.pdf"
            target="_blank"
            rel="noopener noreferrer"
          >
            <ButtonBorderRing />
            <div>
              <img src="/resume.svg" alt="" aria-hidden="true" />
              <span>My resume</span>
            </div>
          </a>
        </div>
      </section>
    </div>
    <div class="right" id="work">
      {
        projects.map((project) => (
          <ProjectCard
            href={`/project/${project.slug}`}
            thumbnailSrc={project.data.thumbnailImage}
            thumbnailAlt={
              PROJECT_THUMBNAIL_ALTS[project.slug] ?? `${project.data.title} thumbnail`
            }
            projectTitle={project.data.title}
            client={project.data.client}
            summary={project.data.summary}
          />
        ))
      }
    </div>
  </main>
</BaseLayout>
